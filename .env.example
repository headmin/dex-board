# DEX Board — Environment variables
# Copy to .env and fill in values, or use 1Password (see setup/deploy.sh --help)

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Worker name on Cloudflare. Change for forks/second deployments to avoid collisions.
WORKER_NAME=dex-board

# ── ClickHouse: Fleet-logs instance ──────────────────────────
# Receives Fleet's structured result/status/audit logs.
# Powers the / Dashboard (heatmaps, processes, security cards).
CLICKHOUSE_URL=https://your-fleetlogs-instance.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=fleet_logs

# ── ClickHouse: Firehose instance ────────────────────────────
# Receives raw osquery snapshots via an S3 ClickPipe.
# Powers /devices, /insights, /reports, Experience Score.
FIREHOSE_CLICKHOUSE_URL=https://your-firehose-instance.clickhouse.cloud:8443
FIREHOSE_CLICKHOUSE_USER=default
FIREHOSE_CLICKHOUSE_PASSWORD=
FIREHOSE_CLICKHOUSE_DATABASE=default
# Name of the S3 ClickPipe destination table on the firehose instance
# (used by setup/setup-clickhouse-firehose.sh to source backfills + MVs).
CLICKPIPE_TABLE=

# Basic auth (optional — leave empty to disable)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Cloudflare Access (optional — leave empty to disable)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Fleet base URL for "Open in Fleet" deep-links (no trailing slash)
# Falls back to https://dogfood.fleetdm.com if unset.
FLEET_URL=https://dogfood.fleetdm.com
