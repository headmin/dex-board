# DEX Board — Environment variables
# Copy to .env and fill in values, or use 1Password (see setup/deploy.sh --help)

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ClickHouse connection
CLICKHOUSE_URL=https://your-instance.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=fleet_logs

# Alt/Firehose ClickHouse connection (osquery result logs)
ALT_CLICKHOUSE_URL=https://your-alt-instance.clickhouse.cloud:8443
ALT_CLICKHOUSE_USER=default
ALT_CLICKHOUSE_PASSWORD=
ALT_CLICKHOUSE_DATABASE=default

# Basic auth (optional — leave empty to disable)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Cloudflare Access (optional — leave empty to disable)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
